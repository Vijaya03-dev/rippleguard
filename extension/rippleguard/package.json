{
  "name": "rippleguard",
  "displayName": "RippleGuard",
  "description": "AI-powered code impact analysis and ripple effect detection. ",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onView:rippleguard.historyView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rippleguard.analyze",
        "title": "RippleGuard: Analyze Impact"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rippleguard-sidebar",
          "title": "RippleGuard",
          "icon": "media/rippleguard-icon.svg"
        }
      ]
    },
    "views": {
      "rippleguard-sidebar": [
        {
          "id": "rippleguard.historyView",
          "name": "Impact History",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
